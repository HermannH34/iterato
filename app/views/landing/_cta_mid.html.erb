<section id="cta-mid" class="py-20 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="font-bold mb-4 text-4xl md:text-5xl tracking-tight"><%= LandingContent::DATA[:cta_mid][:title] %></h2>
      <p class="text-white/50 mb-8 leading-relaxed text-lg max-w-xl mx-auto"><%= LandingContent::DATA[:cta_mid][:subtitle] %></p>
      <div class="flex justify-center flex-col sm:flex-row items-center gap-4">
        <button data-action="click->page-modal#open" data-page-modal-name-param="post-need" class="px-6 py-3 rounded-lg bg-[#FB923C] hover:bg-[#F97316] text-black font-semibold transition-all text-sm"><%= LandingContent::DATA[:cta_mid][:button] %></button>
        <span class="text-white/30 text-sm"><%= LandingContent::DATA[:cta_mid][:mention] %></span>
      </div>
    </div>
  </div>
</section>
