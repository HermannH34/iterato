<section id="jobs" class="py-20 md:py-28 px-6" data-controller="carousel" data-carousel-total-value="<%= LandingContent::DATA[:jobs][:listings].size %>">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-[#FB923C] text-2xl md:text-3xl font-bold tracking-tight mb-4"><%= LandingContent::DATA[:jobs][:tagline] %></h2>
  </div>

  <div class="relative max-w-6xl mx-auto">
    <button data-action="click->carousel#prev" class="absolute -left-4 md:-left-12 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full border border-[#FB923C]/30 bg-[#FB923C]/10 flex items-center justify-center text-[#FB923C] hover:scale-110 transition-transform z-10">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button data-action="click->carousel#next" class="absolute -right-4 md:-right-12 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full border border-[#FB923C]/30 bg-[#FB923C]/10 flex items-center justify-center text-[#FB923C] hover:scale-110 transition-transform z-10">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>

    <div class="overflow-hidden">
      <div class="flex transition-transform duration-500 ease-out" data-carousel-target="track" style="transform: translateX(0%)">
        <% LandingContent::DATA[:jobs][:listings].each do |job| %>
          <div class="w-full flex-shrink-0 px-2">
            <div class="rounded-xl border border-[#FB923C]/30 bg-[#FB923C]/10 p-6 md:p-8 max-w-lg mx-auto">
              <h3 class="font-bold text-xl mb-3"><%= job[:title] %></h3>
              <p class="text-white/50 text-sm leading-relaxed mb-5"><%= job[:description] %></p>
              <div class="flex flex-wrap gap-2 mb-5">
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-[#FB923C]/10 text-[#FB923C] border border-[#FB923C]/30"><%= job[:location] %></span>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-[#FB923C]/10 text-[#FB923C] border border-[#FB923C]/30"><%= job[:type] %></span>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-[#FB923C]/10 text-[#FB923C] border border-[#FB923C]/30"><%= job[:salary] %></span>
              </div>
              <a href="/jobs/<%= job[:slug] %>" class="inline-block px-5 py-2.5 rounded-lg bg-[#FB923C] hover:bg-[#F97316] text-black font-semibold text-sm">Voir le poste</a>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex justify-center gap-2 mt-6" data-carousel-target="dots">
      <% LandingContent::DATA[:jobs][:listings].each_with_index do |_, i| %>
        <button data-action="click->carousel#go" data-index="<%= i %>" class="w-2 h-2 rounded-full transition-all <%= i == 0 ? 'bg-[#FB923C] w-6' : 'bg-white/20' %>"></button>
      <% end %>
    </div>
  </div>
</section>
